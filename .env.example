# ============================================================
# VectorHorizon Environment Variables
# Copy this to .env.local files in frontend/ and worker/wrangler.toml
# ============================================================

# ── Clerk Auth ───────────────────────────────────────────────
# Get from: clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx

# ── Clerk Redirects ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
# Service role key goes in Cloudflare Worker secrets (NOT here):
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ── Cloudflare Worker ────────────────────────────────────────
NEXT_PUBLIC_WORKER_URL=https://vectorhorizon-worker.xxxxx.workers.dev

# ── NVIDIA Cosmos 3 NIM ─────────────────────────────────────
# Get from: build.nvidia.com → Cosmos Predict 2.5 Video2World
NVIDIA_COSMOS_API_KEY=nvapi-xxxxx

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://vectorhorizon.vercel.app
