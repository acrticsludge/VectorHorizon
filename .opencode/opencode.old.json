{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/skills/stack.md",
    ".opencode/skills/practices.md",
    ".opencode/skills/karpathy.md"
  ],
  "share": "manual",
  "model": "deepseek/deepseek-v4-flash",

  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek-V4-Flash",
          "limit": {
            "context": 1048576,
            "output": 262144
          },
          "options": {
            "reasoningEffort": "high",
            "thinking": { "type": "enabled" }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek-V4-Pro",
          "limit": {
            "context": 1048576,
            "output": 262144
          },
          "options": {
            "reasoningEffort": "high",
            "thinking": { "type": "enabled" }
          }
        }
      }
    }
  },

  "mcp": {
    "claude-mem": {
      "type": "local",
      "command": ["npx", "claude-mem", "mcp-server"],
      "enabled": true
    }
  },

  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "read": "allow"
  }
}
