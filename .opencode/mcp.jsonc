// .opencode/mcp.jsonc
// Replace ALL placeholder values before running opencode.
//
// Tokens needed:
//   Supabase access token  → https://supabase.com/dashboard/account/tokens
//   Supabase project_ref   → Supabase dashboard → Settings → General
//   GitHub token           → https://github.com/settings/tokens (scopes: repo, read:org)
//   Vercel token           → https://vercel.com/account/tokens
//   Railway token          → https://railway.app/account/tokens
//   Resend API key         → https://resend.com/api-keys

{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {

    // ── Supabase ──────────────────────────────────────────────────────────────
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref={env:SUPABASE_PROJECT_REF}&read_only=true",
      "headers": {
        "Authorization": "Bearer {env:SUPABASE_ACCESS_TOKEN}"
      },
      "enabled": true
    },

    // ── GitHub ────────────────────────────────────────────────────────────────
    // ⚠️ ~20k token cost per session. Disabled by default.
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": false
    },

    // ── Vercel ────────────────────────────────────────────────────────────────
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:VERCEL_TOKEN}"
      },
      "enabled": true
    },

    // ── Railway ───────────────────────────────────────────────────────────────
    "railway": {
      "type": "local",
      "command": ["npx", "-y", "@railway/mcp-server"],
      "environment": {
        "RAILWAY_API_TOKEN": "{env:RAILWAY_API_TOKEN}"
      },
      "enabled": true
    },

    // ── Resend ────────────────────────────────────────────────────────────────
    "resend": {
      "type": "remote",
      "url": "https://mcp.resend.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:RESEND_API_KEY}"
      },
      "enabled": true
    },

    // ── shadcn/ui ─────────────────────────────────────────────────────────────
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    },

    // ── Magic UI ──────────────────────────────────────────────────────────────
    "magicui": {
      "type": "local",
      "command": ["npx", "-y", "@magicuidesign/mcp@latest"],
      "enabled": true
    },

    // ── Playwright ────────────────────────────────────────────────────────────
    // ⚠️ Spins up a real browser — disable when not actively testing.
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": false
    },

    // ── Claude-Mem ────────────────────────────────────────────────────────────
    "claude-mem": {
      "type": "local",
      "command": ["npx", "claude-mem", "mcp-server"],
      "enabled": true
    },

    // ── LLMAtlas ─────────────────────────────────────────────────────────────
    // Uses local build. Change to npx @llm-atlas/cli once v1.0.3 is published.
    "llm-atlas": {
      "type": "local",
      "command": ["node", "C:\\Anubhav\\Web Dev Projects\\LLMAtlas\\cli\\dist\\index.js", "mcp"],
      "enabled": true
    },

    // ── Google Stitch ─────────────────────────────────────────────────────────
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:GOOGLE_API_KEY}"
      }
    }

  }
}